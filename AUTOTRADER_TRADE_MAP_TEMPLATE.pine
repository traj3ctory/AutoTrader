//@version=5
indicator("AutoTrader Trade Map", overlay=true, max_lines_count=80, max_labels_count=80)

// Generated from SETUP_LEDGER.json. Do not hand-edit coin levels here.
// Reanalyze updates one ledger record, then rebuilds this multi-symbol map.
// Card shows ledger state; the Live row reports level tags since analyzed_at
// and always means "reanalyze", never "the ledger changed by itself".

showMap = (syminfo.prefix == "BYBIT" and syminfo.ticker == "APEUSDT.P") or (syminfo.prefix == "BYBIT" and syminfo.ticker == "FARTCOINUSDT.P") or (syminfo.prefix == "BYBIT" and syminfo.ticker == "USUSDT.P") or (syminfo.prefix == "BYBIT" and syminfo.ticker == "JTOUSDT.P") or (syminfo.prefix == "BYBIT" and syminfo.ticker == "XRPUSDT.P") or (syminfo.prefix == "BYBIT" and syminfo.ticker == "KMNOUSDT.P")

coin = (syminfo.prefix == "BYBIT" and syminfo.ticker == "APEUSDT.P") ? "APEUSDT.P" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "FARTCOINUSDT.P") ? "FARTCOINUSDT.P" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "USUSDT.P") ? "USUSDT.P" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "JTOUSDT.P") ? "JTOUSDT.P" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "XRPUSDT.P") ? "XRPUSDT.P" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "KMNOUSDT.P") ? "KMNOUSDT.P" : ""
tradeType = (syminfo.prefix == "BYBIT" and syminfo.ticker == "APEUSDT.P") ? "Intraday" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "FARTCOINUSDT.P") ? "Scalp" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "USUSDT.P") ? "Intraday" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "JTOUSDT.P") ? "Intraday" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "XRPUSDT.P") ? "Intraday" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "KMNOUSDT.P") ? "Intraday" : ""
planText = (syminfo.prefix == "BYBIT" and syminfo.ticker == "APEUSDT.P") ? "Cond. Long · Watch Only" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "FARTCOINUSDT.P") ? "No Trade · Watch Only" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "USUSDT.P") ? "Cond. Long · Watch Only" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "JTOUSDT.P") ? "Cond. Long · Watch Only" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "XRPUSDT.P") ? "Cond. Long · Watch Only" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "KMNOUSDT.P") ? "Cond. Long · Watch Only" : ""
planColorName = (syminfo.prefix == "BYBIT" and syminfo.ticker == "APEUSDT.P") ? "blue" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "FARTCOINUSDT.P") ? "gray" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "USUSDT.P") ? "blue" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "JTOUSDT.P") ? "blue" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "XRPUSDT.P") ? "blue" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "KMNOUSDT.P") ? "blue" : "blue"
setupState = (syminfo.prefix == "BYBIT" and syminfo.ticker == "APEUSDT.P") ? "WAIT REACTION" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "FARTCOINUSDT.P") ? "MISSED / NO CHASE" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "USUSDT.P") ? "WAIT REACTION" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "JTOUSDT.P") ? "WAIT REACTION" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "XRPUSDT.P") ? "WAIT RECLAIM" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "KMNOUSDT.P") ? "WAIT RETEST" : ""
positionState = (syminfo.prefix == "BYBIT" and syminfo.ticker == "APEUSDT.P") ? "NO POSITION" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "FARTCOINUSDT.P") ? "NO POSITION" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "USUSDT.P") ? "NO POSITION" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "JTOUSDT.P") ? "NO POSITION" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "XRPUSDT.P") ? "NO POSITION" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "KMNOUSDT.P") ? "NO POSITION" : ""
rrText = (syminfo.prefix == "BYBIT" and syminfo.ticker == "APEUSDT.P") ? "2.1R / 3.1R" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "FARTCOINUSDT.P") ? "1.3R / 2.1R · FAILS TP1 >= 1.5" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "USUSDT.P") ? "2.2R / 3.0R" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "JTOUSDT.P") ? "2.0R / 3.0R" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "XRPUSDT.P") ? "2.3R / 3.7R" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "KMNOUSDT.P") ? "2.5R / 3.3R" : ""
rrColorName = (syminfo.prefix == "BYBIT" and syminfo.ticker == "APEUSDT.P") ? "green" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "FARTCOINUSDT.P") ? "red" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "USUSDT.P") ? "green" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "JTOUSDT.P") ? "green" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "XRPUSDT.P") ? "green" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "KMNOUSDT.P") ? "green" : "green"
isLong = (syminfo.prefix == "BYBIT" and syminfo.ticker == "APEUSDT.P") ? true : (syminfo.prefix == "BYBIT" and syminfo.ticker == "FARTCOINUSDT.P") ? false : (syminfo.prefix == "BYBIT" and syminfo.ticker == "USUSDT.P") ? true : (syminfo.prefix == "BYBIT" and syminfo.ticker == "JTOUSDT.P") ? true : (syminfo.prefix == "BYBIT" and syminfo.ticker == "XRPUSDT.P") ? true : (syminfo.prefix == "BYBIT" and syminfo.ticker == "KMNOUSDT.P") ? true : true
needsReclaim = (syminfo.prefix == "BYBIT" and syminfo.ticker == "APEUSDT.P") ? true : (syminfo.prefix == "BYBIT" and syminfo.ticker == "FARTCOINUSDT.P") ? false : (syminfo.prefix == "BYBIT" and syminfo.ticker == "USUSDT.P") ? false : (syminfo.prefix == "BYBIT" and syminfo.ticker == "JTOUSDT.P") ? false : (syminfo.prefix == "BYBIT" and syminfo.ticker == "XRPUSDT.P") ? false : (syminfo.prefix == "BYBIT" and syminfo.ticker == "KMNOUSDT.P") ? false : false

entryLow = (syminfo.prefix == "BYBIT" and syminfo.ticker == "APEUSDT.P") ? 0.1345 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "FARTCOINUSDT.P") ? 0.1428 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "USUSDT.P") ? 0.0164 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "JTOUSDT.P") ? 0.665 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "XRPUSDT.P") ? 1.095 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "KMNOUSDT.P") ? 0.0185 : na
entryHigh = (syminfo.prefix == "BYBIT" and syminfo.ticker == "APEUSDT.P") ? 0.1375 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "FARTCOINUSDT.P") ? 0.1437 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "USUSDT.P") ? 0.0172 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "JTOUSDT.P") ? 0.68 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "XRPUSDT.P") ? 1.1045 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "KMNOUSDT.P") ? 0.019 : na
reclaim = (syminfo.prefix == "BYBIT" and syminfo.ticker == "APEUSDT.P") ? 0.152 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "FARTCOINUSDT.P") ? 0.1428 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "USUSDT.P") ? 0.0182 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "JTOUSDT.P") ? 0.68 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "XRPUSDT.P") ? 1.1045 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "KMNOUSDT.P") ? 0.0195 : na
sl = (syminfo.prefix == "BYBIT" and syminfo.ticker == "APEUSDT.P") ? 0.1295 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "FARTCOINUSDT.P") ? 0.1468 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "USUSDT.P") ? 0.0157 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "JTOUSDT.P") ? 0.645 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "XRPUSDT.P") ? 1.072 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "KMNOUSDT.P") ? 0.0178 : na
tp1 = (syminfo.prefix == "BYBIT" and syminfo.ticker == "APEUSDT.P") ? 0.154 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "FARTCOINUSDT.P") ? 0.1376 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "USUSDT.P") ? 0.0205 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "JTOUSDT.P") ? 0.75 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "XRPUSDT.P") ? 1.18 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "KMNOUSDT.P") ? 0.022 : na
tp2 = (syminfo.prefix == "BYBIT" and syminfo.ticker == "APEUSDT.P") ? 0.162 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "FARTCOINUSDT.P") ? 0.1345 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "USUSDT.P") ? 0.0217 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "JTOUSDT.P") ? 0.785 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "XRPUSDT.P") ? 1.225 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "KMNOUSDT.P") ? 0.023 : na
tp3 = (syminfo.prefix == "BYBIT" and syminfo.ticker == "APEUSDT.P") ? 0.17 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "FARTCOINUSDT.P") ? 0.128 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "USUSDT.P") ? 0.024 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "JTOUSDT.P") ? 0.84 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "XRPUSDT.P") ? 1.3 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "KMNOUSDT.P") ? 0.026 : na
actualEntry = (syminfo.prefix == "BYBIT" and syminfo.ticker == "APEUSDT.P") ? 0 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "FARTCOINUSDT.P") ? 0 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "USUSDT.P") ? 0 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "JTOUSDT.P") ? 0 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "XRPUSDT.P") ? 0 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "KMNOUSDT.P") ? 0 : 0.0
activeFrom = (syminfo.prefix == "BYBIT" and syminfo.ticker == "APEUSDT.P") ? na : (syminfo.prefix == "BYBIT" and syminfo.ticker == "FARTCOINUSDT.P") ? na : (syminfo.prefix == "BYBIT" and syminfo.ticker == "USUSDT.P") ? na : (syminfo.prefix == "BYBIT" and syminfo.ticker == "JTOUSDT.P") ? na : (syminfo.prefix == "BYBIT" and syminfo.ticker == "XRPUSDT.P") ? na : (syminfo.prefix == "BYBIT" and syminfo.ticker == "KMNOUSDT.P") ? na : na
analyzedAt = (syminfo.prefix == "BYBIT" and syminfo.ticker == "APEUSDT.P") ? 1783511220000 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "FARTCOINUSDT.P") ? 1782974340000 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "USUSDT.P") ? 1783401960000 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "JTOUSDT.P") ? 1783941494000 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "XRPUSDT.P") ? 1783941494000 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "KMNOUSDT.P") ? 1783582080202 : na

green = color.rgb(34, 197, 94)
red = color.rgb(255, 82, 82)
blue = color.rgb(47, 128, 237)
grey = color.rgb(140, 140, 140)
orange = color.rgb(245, 158, 11)
neutral = color.rgb(107, 114, 128)

colorOf(string name) =>
    name == "red" ? red : name == "orange" ? orange : name == "green" ? green : name == "gray" ? neutral : blue

enteredLong = positionState == "ENTERED LONG" and actualEntry > 0
enteredShort = positionState == "ENTERED SHORT" and actualEntry > 0

entryEdge = isLong ? math.max(entryLow, entryHigh) : math.min(entryLow, entryHigh)
riskSize = math.abs(entryEdge - sl)
rr1v = riskSize > 0 and not na(tp1) ? (isLong ? tp1 - entryEdge : entryEdge - tp1) / riskSize : na
rr2v = riskSize > 0 and not na(tp2) ? (isLong ? tp2 - entryEdge : entryEdge - tp2) / riskSize : na
rr3v = riskSize > 0 and not na(tp3) ? (isLong ? tp3 - entryEdge : entryEdge - tp3) / riskSize : na

anchorTime = na(activeFrom) or activeFrom <= 0 ? analyzedAt : activeFrom
activeBar = showMap and not na(anchorTime) and time >= anchorTime
// The reclaim lifecycle is decided only by completed candles. A forming bar
// can wick across the level, but must not change the Live row.
reclaimSideOk = activeBar and barstate.isconfirmed and not na(reclaim) and (isLong ? close >= reclaim : close <= reclaim)
reclaimSideLost = activeBar and barstate.isconfirmed and not na(reclaim) and (isLong ? close < reclaim : close > reclaim)
entryTouchedNow = activeBar and not na(entryLow) and not na(entryHigh) and high >= math.min(entryLow, entryHigh) and low <= math.max(entryLow, entryHigh)
tp1TouchedNow = activeBar and not na(tp1) and (isLong ? high >= tp1 : low <= tp1)
tp2TouchedNow = activeBar and not na(tp2) and (isLong ? high >= tp2 : low <= tp2)
tp3TouchedNow = activeBar and not na(tp3) and (isLong ? high >= tp3 : low <= tp3)
slTouchedNow = activeBar and not na(sl) and (isLong ? low <= sl : high >= sl)

var bool reclaimSeen = false
var bool holdLostSeen = false
var bool closedRightSeen = false
var bool closedWrongSeen = false
var bool entrySeen = false
var bool tp1Seen = false
var bool tp2Seen = false
var bool tp3Seen = false
var bool invalidSeen = false
var int reclaimTime = na
var int holdLostTime = na
var int reclaimStatus = 0
var int reclaimStatusTime = na
var int entryTime = na
var int tp1Time = na
var int tp2Time = na
var int tp3Time = na
var int slTime = na

// Reclaim events are close-confirmed crossings, never wick touches, and only
// count when price was on the other side of the line since the anchor.
// Flat (non-nested) ternary form on purpose: Pine's indentation is
// significant, and deeply nested if-blocks here have repeatedly been
// corrupted by editor auto-indent during automated paste. Keep this section
// free of nested if statements.
reclaimJustCrossed = showMap and reclaimSideOk and closedWrongSeen and not reclaimSideOk[1]
reclaimTime := reclaimJustCrossed ? time : reclaimTime
reclaimSeen := showMap and (reclaimSeen or reclaimJustCrossed)
closedRightSeen := showMap and (closedRightSeen or reclaimSideOk)

holdLostJustCrossed = showMap and reclaimSideLost and closedRightSeen and not reclaimSideLost[1]
holdLostTime := holdLostJustCrossed ? time : holdLostTime
holdLostSeen := showMap and (holdLostSeen or holdLostJustCrossed)
closedWrongSeen := showMap and (closedWrongSeen or reclaimSideLost)
reclaimStatus := reclaimJustCrossed ? 1 : holdLostJustCrossed ? -1 : reclaimStatus
reclaimStatusTime := reclaimJustCrossed or holdLostJustCrossed ? time : reclaimStatusTime

entryOk = showMap and entryTouchedNow and (needsReclaim ? reclaimSeen : true)
entryJustSeen = entryOk and not entrySeen
entryTime := entryJustSeen ? time : entryTime
entrySeen := showMap and (entrySeen or entryOk)

tp1JustSeen = showMap and tp1TouchedNow and not tp1Seen
tp1Time := tp1JustSeen ? time : tp1Time
tp1Seen := showMap and (tp1Seen or tp1TouchedNow)

tp2JustSeen = showMap and tp2TouchedNow and not tp2Seen
tp2Time := tp2JustSeen ? time : tp2Time
tp2Seen := showMap and (tp2Seen or tp2TouchedNow)

tp3JustSeen = showMap and tp3TouchedNow and not tp3Seen
tp3Time := tp3JustSeen ? time : tp3Time
tp3Seen := showMap and (tp3Seen or tp3TouchedNow)

slJustSeen = showMap and slTouchedNow and not invalidSeen
slTime := slJustSeen ? time : slTime
invalidSeen := showMap and (invalidSeen or slTouchedNow)

liveEvent = invalidSeen ? "SL TAGGED" : tp3Seen ? "TP3 TAGGED" : tp2Seen ? "TP2 TAGGED" : tp1Seen ? "TP1 TAGGED" : entrySeen ? "ENTRY TAGGED" : reclaimStatus == -1 ? "RECLAIM LOST" : reclaimStatus == 1 ? "RECLAIMED" : ""
liveTime = invalidSeen ? slTime : tp3Seen ? tp3Time : tp2Seen ? tp2Time : tp1Seen ? tp1Time : entrySeen ? entryTime : reclaimStatusTime

plState = enteredLong ? (close >= actualEntry ? "UR PROFIT" : "UR LOSS") : enteredShort ? (close <= actualEntry ? "UR PROFIT" : "UR LOSS") : positionState
statusText = setupState + " / " + plState

plot(showMap ? entryLow : na, "Entry Bottom", color=green, linewidth=2, display=display.all - display.status_line)
plot(showMap ? entryHigh : na, "Entry Top", color=green, linewidth=2, display=display.all - display.status_line)
plot(showMap ? reclaim : na, "Reclaim", color=blue, linewidth=2, display=display.all - display.status_line)
plot(showMap ? sl : na, "Invalid / SL", color=red, linewidth=2, display=display.all - display.status_line)
plot(showMap ? tp1 : na, "TP1", color=isLong ? green : red, linewidth=2, display=display.all - display.status_line)
plot(showMap ? tp2 : na, "TP2", color=isLong ? green : red, linewidth=2, display=display.all - display.status_line)
plot(showMap and not na(tp3) ? tp3 : na, "TP3", color=grey, linewidth=2, display=display.all - display.status_line)

var label lEntry = na
var label lReclaim = na
var label lSL = na
var label lTP1 = na
var label lTP2 = na
var label lTP3 = na
var label lState = na
var line gEntryLow = na
var line gEntryHigh = na
var line gReclaim = na
var line gSL = na
var line gTP1 = na
var line gTP2 = na
var line gTP3 = na

makeLabel(label old, float y, string txt, color bg) =>
    if not na(old)
        label.delete(old)
    label.new(bar_index + 80, y, txt, xloc=xloc.bar_index, yloc=yloc.price, style=label.style_label_left, color=bg, textcolor=color.white, size=size.small)

makeGuide(line old, float y, color c) =>
    if not na(old)
        line.delete(old)
    line.new(bar_index, y, bar_index + 80, y, xloc=xloc.bar_index, extend=extend.none, color=c, width=2)

if barstate.islast
    if showMap
        gEntryLow := makeGuide(gEntryLow, entryLow, green)
        gEntryHigh := makeGuide(gEntryHigh, entryHigh, green)
        gReclaim := makeGuide(gReclaim, reclaim, blue)
        gSL := makeGuide(gSL, sl, red)
        gTP1 := makeGuide(gTP1, tp1, isLong ? green : red)
        gTP2 := makeGuide(gTP2, tp2, isLong ? green : red)
        if not na(tp3)
            gTP3 := makeGuide(gTP3, tp3, grey)
        lEntry := makeLabel(lEntry, (entryLow + entryHigh) / 2.0, "ENTRY " + str.tostring(entryLow) + "-" + str.tostring(entryHigh), green)
        lReclaim := makeLabel(lReclaim, reclaim, "RECLAIM " + str.tostring(reclaim), blue)
        lSL := makeLabel(lSL, sl, "SL " + str.tostring(sl), red)
        lTP1 := makeLabel(lTP1, tp1, "TP1 " + str.tostring(tp1) + " · " + str.tostring(rr1v, "#.#") + "R", isLong ? green : red)
        lTP2 := makeLabel(lTP2, tp2, "TP2 " + str.tostring(tp2) + " · " + str.tostring(rr2v, "#.#") + "R", isLong ? green : red)
        if not na(tp3)
            lTP3 := makeLabel(lTP3, tp3, "TP3 " + str.tostring(tp3) + " · " + str.tostring(rr3v, "#.#") + "R", grey)
        lState := makeLabel(lState, close, statusText, plState == "UR PROFIT" ? green : plState == "UR LOSS" ? red : orange)
    else
        if not na(lEntry)
            label.delete(lEntry)
            label.delete(lReclaim)
            label.delete(lSL)
            label.delete(lTP1)
            label.delete(lTP2)
            label.delete(lTP3)
            label.delete(lState)
            line.delete(gEntryLow)
            line.delete(gEntryHigh)
            line.delete(gReclaim)
            line.delete(gSL)
            line.delete(gTP1)
            line.delete(gTP2)
            line.delete(gTP3)

var table t = table.new(position.top_right, 2, 6, border_width=1)

cell(int row, string leftTxt, string rightTxt, color bg) =>
    table.cell(t, 0, row, leftTxt, text_color=color.white, bgcolor=color.rgb(55, 65, 81))
    table.cell(t, 1, row, rightTxt, text_color=color.white, bgcolor=bg)

if barstate.islast
    table.clear(t, 0, 0, 1, 5)
    if showMap
        staleMs = tradeType == "Scalp" ? 43200000 : 86400000
        ageMs = na(analyzedAt) ? staleMs * 2.0 : timenow - analyzedAt
        updatedTxt = na(analyzedAt) ? "UNKNOWN" : str.format_time(int(analyzedAt), "MMM d · HH:mm", "GMT+1")
        updatedColor = ageMs >= staleMs ? red : ageMs >= staleMs / 2 ? orange : neutral
        stateColor = str.contains(setupState, "INVALID") or plState == "UR LOSS" ? red : plState == "UR PROFIT" or str.contains(setupState, "ACTIVE") ? green : orange
        cell(0, "Coin", coin + " · " + tradeType, neutral)
        cell(1, "Plan", planText, colorOf(planColorName))
        cell(2, "State", setupState + " · " + plState, stateColor)
        cell(3, "R:R", rrText, colorOf(rrColorName))
        cell(4, "Updated", updatedTxt, updatedColor)
        if liveEvent != "" and not na(liveTime)
            cell(5, "Live", liveEvent + " · " + str.format_time(liveTime, "MMM d HH:mm", "GMT+1") + " · REANALYZE", liveEvent == "SL TAGGED" ? red : orange)
