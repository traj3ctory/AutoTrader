//@version=5
indicator("Codex Trade Map", overlay=true, max_lines_count=80, max_labels_count=80)

// Generated from SETUP_LEDGER.json. Do not hand-edit coin levels here.
// Reanalyze updates one ledger record, then rebuilds this multi-symbol map.

showMap = (syminfo.prefix == "BYBIT" and syminfo.ticker == "XRPUSDT.P") or (syminfo.prefix == "BYBIT" and syminfo.ticker == "AVAXUSDT.P") or (syminfo.prefix == "BYBIT" and syminfo.ticker == "SPORTFUNUSDT.P") or (syminfo.prefix == "BYBIT" and syminfo.ticker == "DOGEUSDT.P") or (syminfo.prefix == "BYBIT" and syminfo.ticker == "HYPEUSDT.P") or (syminfo.prefix == "BYBIT" and syminfo.ticker == "FARTCOINUSDT.P") or (syminfo.prefix == "BYBIT" and syminfo.ticker == "ETHUSDT.P")

coin = (syminfo.prefix == "BYBIT" and syminfo.ticker == "XRPUSDT.P") ? "XRPUSDT.P" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "AVAXUSDT.P") ? "AVAXUSDT.P" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "SPORTFUNUSDT.P") ? "SPORTFUNUSDT.P" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "DOGEUSDT.P") ? "DOGEUSDT.P" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "HYPEUSDT.P") ? "HYPEUSDT.P" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "FARTCOINUSDT.P") ? "FARTCOINUSDT.P" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "ETHUSDT.P") ? "ETHUSDT.P" : ""
tradeType = (syminfo.prefix == "BYBIT" and syminfo.ticker == "XRPUSDT.P") ? "Scalp" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "AVAXUSDT.P") ? "Scalp" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "SPORTFUNUSDT.P") ? "Scalp" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "DOGEUSDT.P") ? "Scalp" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "HYPEUSDT.P") ? "Scalp" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "FARTCOINUSDT.P") ? "Scalp" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "ETHUSDT.P") ? "Scalp" : ""
direction = (syminfo.prefix == "BYBIT" and syminfo.ticker == "XRPUSDT.P") ? "Proposed Wait / Conditional Long" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "AVAXUSDT.P") ? "Proposed Wait / Conditional Long" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "SPORTFUNUSDT.P") ? "Proposed Wait / Conditional Long" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "DOGEUSDT.P") ? "Proposed Wait / Conditional Long" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "HYPEUSDT.P") ? "Proposed Wait / Conditional Long" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "FARTCOINUSDT.P") ? "Proposed Wait / No Trade" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "ETHUSDT.P") ? "Proposed Wait / Conditional Long" : ""
rating = (syminfo.prefix == "BYBIT" and syminfo.ticker == "XRPUSDT.P") ? "Watch Only" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "AVAXUSDT.P") ? "Watch Only" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "SPORTFUNUSDT.P") ? "Watch Only" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "DOGEUSDT.P") ? "Watch Only" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "HYPEUSDT.P") ? "Watch Only" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "FARTCOINUSDT.P") ? "Watch Only" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "ETHUSDT.P") ? "Watch Only" : ""
setupState = (syminfo.prefix == "BYBIT" and syminfo.ticker == "XRPUSDT.P") ? "WAIT RETEST" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "AVAXUSDT.P") ? "WAIT RECLAIM" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "SPORTFUNUSDT.P") ? "WAIT RETEST" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "DOGEUSDT.P") ? "WAIT RECLAIM" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "HYPEUSDT.P") ? "WAIT RECLAIM" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "FARTCOINUSDT.P") ? "WAIT REACTION" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "ETHUSDT.P") ? "WAIT RETEST" : ""
positionState = (syminfo.prefix == "BYBIT" and syminfo.ticker == "XRPUSDT.P") ? "NO POSITION" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "AVAXUSDT.P") ? "NO POSITION" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "SPORTFUNUSDT.P") ? "NO POSITION" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "DOGEUSDT.P") ? "NO POSITION" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "HYPEUSDT.P") ? "NO POSITION" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "FARTCOINUSDT.P") ? "NO POSITION" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "ETHUSDT.P") ? "NO POSITION" : ""
mode = (syminfo.prefix == "BYBIT" and syminfo.ticker == "XRPUSDT.P") ? "RECLAIM 1.05" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "AVAXUSDT.P") ? "RECLAIM 6.7" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "SPORTFUNUSDT.P") ? "RECLAIM 0.0245" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "DOGEUSDT.P") ? "RECLAIM 0.07265" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "HYPEUSDT.P") ? "RECLAIM 63.75" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "FARTCOINUSDT.P") ? "RECLAIM 0.1428" : (syminfo.prefix == "BYBIT" and syminfo.ticker == "ETHUSDT.P") ? "RECLAIM 1615" : ""
isLong = (syminfo.prefix == "BYBIT" and syminfo.ticker == "XRPUSDT.P") ? true : (syminfo.prefix == "BYBIT" and syminfo.ticker == "AVAXUSDT.P") ? true : (syminfo.prefix == "BYBIT" and syminfo.ticker == "SPORTFUNUSDT.P") ? true : (syminfo.prefix == "BYBIT" and syminfo.ticker == "DOGEUSDT.P") ? true : (syminfo.prefix == "BYBIT" and syminfo.ticker == "HYPEUSDT.P") ? true : (syminfo.prefix == "BYBIT" and syminfo.ticker == "FARTCOINUSDT.P") ? false : (syminfo.prefix == "BYBIT" and syminfo.ticker == "ETHUSDT.P") ? true : true

entryLow = (syminfo.prefix == "BYBIT" and syminfo.ticker == "XRPUSDT.P") ? 1.048 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "AVAXUSDT.P") ? 6.62 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "SPORTFUNUSDT.P") ? 0.0239 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "DOGEUSDT.P") ? 0.0719 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "HYPEUSDT.P") ? 62.95 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "FARTCOINUSDT.P") ? 0.1428 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "ETHUSDT.P") ? 1592 : na
entryHigh = (syminfo.prefix == "BYBIT" and syminfo.ticker == "XRPUSDT.P") ? 1.052 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "AVAXUSDT.P") ? 6.66 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "SPORTFUNUSDT.P") ? 0.0242 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "DOGEUSDT.P") ? 0.07215 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "HYPEUSDT.P") ? 63.2 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "FARTCOINUSDT.P") ? 0.1437 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "ETHUSDT.P") ? 1598 : na
reclaim = (syminfo.prefix == "BYBIT" and syminfo.ticker == "XRPUSDT.P") ? 1.05 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "AVAXUSDT.P") ? 6.7 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "SPORTFUNUSDT.P") ? 0.0245 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "DOGEUSDT.P") ? 0.07265 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "HYPEUSDT.P") ? 63.75 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "FARTCOINUSDT.P") ? 0.1428 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "ETHUSDT.P") ? 1615 : na
sl = (syminfo.prefix == "BYBIT" and syminfo.ticker == "XRPUSDT.P") ? 1.039 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "AVAXUSDT.P") ? 6.54 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "SPORTFUNUSDT.P") ? 0.0232 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "DOGEUSDT.P") ? 0.07145 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "HYPEUSDT.P") ? 62.55 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "FARTCOINUSDT.P") ? 0.1468 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "ETHUSDT.P") ? 1584 : na
tp1 = (syminfo.prefix == "BYBIT" and syminfo.ticker == "XRPUSDT.P") ? 1.066 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "AVAXUSDT.P") ? 6.82 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "SPORTFUNUSDT.P") ? 0.0252 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "DOGEUSDT.P") ? 0.07325 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "HYPEUSDT.P") ? 64.05 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "FARTCOINUSDT.P") ? 0.1376 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "ETHUSDT.P") ? 1615 : na
tp2 = (syminfo.prefix == "BYBIT" and syminfo.ticker == "XRPUSDT.P") ? 1.075 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "AVAXUSDT.P") ? 6.95 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "SPORTFUNUSDT.P") ? 0.026 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "DOGEUSDT.P") ? 0.07375 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "HYPEUSDT.P") ? 64.55 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "FARTCOINUSDT.P") ? 0.1345 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "ETHUSDT.P") ? 1630 : na
tp3 = (syminfo.prefix == "BYBIT" and syminfo.ticker == "XRPUSDT.P") ? 1.105 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "AVAXUSDT.P") ? 7.1 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "SPORTFUNUSDT.P") ? 0.0266 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "DOGEUSDT.P") ? 0.0741 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "HYPEUSDT.P") ? 65.05 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "FARTCOINUSDT.P") ? 0.128 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "ETHUSDT.P") ? 1642 : na
actualEntry = (syminfo.prefix == "BYBIT" and syminfo.ticker == "XRPUSDT.P") ? 0 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "AVAXUSDT.P") ? 0 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "SPORTFUNUSDT.P") ? 0 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "DOGEUSDT.P") ? 0 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "HYPEUSDT.P") ? 0 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "FARTCOINUSDT.P") ? 0 : (syminfo.prefix == "BYBIT" and syminfo.ticker == "ETHUSDT.P") ? 0 : 0.0

green = color.rgb(34, 197, 94)
red = color.rgb(255, 82, 82)
blue = color.rgb(47, 128, 237)
grey = color.rgb(140, 140, 140)
orange = color.rgb(245, 158, 11)
neutral = color.rgb(107, 114, 128)

enteredLong = positionState == "ENTERED LONG" and actualEntry > 0
enteredShort = positionState == "ENTERED SHORT" and actualEntry > 0
plState = enteredLong ? (close >= actualEntry ? "UR PROFIT" : "UR LOSS") : enteredShort ? (close <= actualEntry ? "UR PROFIT" : "UR LOSS") : positionState
statusText = setupState + " / " + plState

plot(showMap ? entryLow : na, "Entry Bottom", color=green, linewidth=2, display=display.all - display.status_line)
plot(showMap ? entryHigh : na, "Entry Top", color=green, linewidth=2, display=display.all - display.status_line)
plot(showMap ? reclaim : na, "Reclaim", color=blue, linewidth=2, display=display.all - display.status_line)
plot(showMap ? sl : na, "Invalid / SL", color=red, linewidth=2, display=display.all - display.status_line)
plot(showMap ? tp1 : na, "TP1", color=isLong ? green : red, linewidth=2, display=display.all - display.status_line)
plot(showMap ? tp2 : na, "TP2", color=isLong ? green : red, linewidth=2, display=display.all - display.status_line)
plot(showMap and not na(tp3) ? tp3 : na, "TP3", color=grey, linewidth=2, display=display.all - display.status_line)

var label lEntry = na
var label lReclaim = na
var label lSL = na
var label lTP1 = na
var label lTP2 = na
var label lTP3 = na
var label lState = na
var line gEntryLow = na
var line gEntryHigh = na
var line gReclaim = na
var line gSL = na
var line gTP1 = na
var line gTP2 = na
var line gTP3 = na

makeLabel(label old, float y, string txt, color bg) =>
    if not na(old)
        label.delete(old)
    label.new(bar_index + 5, y, txt, xloc=xloc.bar_index, yloc=yloc.price, style=label.style_label_left, color=bg, textcolor=color.white, size=size.small)

makeGuide(line old, float y, color c) =>
    if not na(old)
        line.delete(old)
    line.new(bar_index, y, bar_index + 5, y, xloc=xloc.bar_index, extend=extend.none, color=c, width=2)

if barstate.islast
    if showMap
        gEntryLow := makeGuide(gEntryLow, entryLow, green)
        gEntryHigh := makeGuide(gEntryHigh, entryHigh, green)
        gReclaim := makeGuide(gReclaim, reclaim, blue)
        gSL := makeGuide(gSL, sl, red)
        gTP1 := makeGuide(gTP1, tp1, isLong ? green : red)
        gTP2 := makeGuide(gTP2, tp2, isLong ? green : red)
        if not na(tp3)
            gTP3 := makeGuide(gTP3, tp3, grey)
        lEntry := makeLabel(lEntry, (entryLow + entryHigh) / 2.0, "ENTRY " + str.tostring(entryLow) + "-" + str.tostring(entryHigh), green)
        lReclaim := makeLabel(lReclaim, reclaim, "RECLAIM " + str.tostring(reclaim), blue)
        lSL := makeLabel(lSL, sl, "INVALID " + str.tostring(sl), red)
        lTP1 := makeLabel(lTP1, tp1, "TP1 " + str.tostring(tp1), isLong ? green : red)
        lTP2 := makeLabel(lTP2, tp2, "TP2 " + str.tostring(tp2), isLong ? green : red)
        if not na(tp3)
            lTP3 := makeLabel(lTP3, tp3, "TP3 " + str.tostring(tp3), grey)
        lState := makeLabel(lState, close, statusText, plState == "UR PROFIT" ? green : plState == "UR LOSS" ? red : orange)
    else
        if not na(lEntry)
            label.delete(lEntry)
            label.delete(lReclaim)
            label.delete(lSL)
            label.delete(lTP1)
            label.delete(lTP2)
            label.delete(lTP3)
            label.delete(lState)
            line.delete(gEntryLow)
            line.delete(gEntryHigh)
            line.delete(gReclaim)
            line.delete(gSL)
            line.delete(gTP1)
            line.delete(gTP2)
            line.delete(gTP3)

var table t = table.new(position.top_right, 2, 9, border_width=1)

cell(int row, string left, string right, color bg) =>
    table.cell(t, 0, row, left, text_color=color.white, bgcolor=color.rgb(55, 65, 81))
    table.cell(t, 1, row, right, text_color=color.white, bgcolor=bg)

if barstate.islast
    table.clear(t, 0, 0, 1, 8)
    if showMap
        cell(0, "Coin", coin, neutral)
        cell(1, "Trade Type", tradeType, blue)
        cell(2, "Direction", direction, str.contains(direction, "WAIT") ? orange : blue)
        cell(3, "Rating", rating, rating == "Clean Trade" ? green : rating == "Conditional Trade" ? orange : neutral)
        cell(4, "State", setupState, str.contains(setupState, "WAIT") ? orange : green)
        cell(5, "Position", plState, plState == "UR PROFIT" ? green : plState == "UR LOSS" ? red : neutral)
        cell(6, "Entry", str.tostring(entryLow) + "-" + str.tostring(entryHigh), green)
        cell(7, "SL / TP", str.tostring(sl) + " / " + str.tostring(tp1) + " / " + str.tostring(tp2) + (na(tp3) ? "" : " / " + str.tostring(tp3)), isLong ? green : red)
        cell(8, "Mode", mode, blue)
